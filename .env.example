VITE_API_URL=/api/v1
VITE_GOOGLE_CLIENT_ID=
# Google Gemini API key(s) for AI writing evaluation + study assistant.
# Get keys at https://aistudio.google.com/apikey
# You can add MANY keys to multiply the free daily quota. Two ways (combine if you like):
#   1) Comma-separate them in one var:  VITE_GEMINI_API_KEY=key1,key2,key3
#   2) Or use numbered vars:            VITE_GEMINI_API_KEY_2, _3, _4, _5
# For separate quotas, create each key in a DIFFERENT Google account/project
# (keys in the same project share the same quota).
VITE_GEMINI_API_KEY=
VITE_GEMINI_API_KEY_2=
VITE_GEMINI_API_KEY_3=
