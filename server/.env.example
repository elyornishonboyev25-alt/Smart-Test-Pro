# Copy to .env and edit as needed for local development
# If using Firebase service account, paste JSON into FIREBASE_SERVICE_ACCOUNT (single-line escaped JSON)
# Or leave empty to use emulator & default app credentials
FIREBASE_PROJECT_ID=eduverse-pro
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=http://localhost:9099
ADMIN_UID=
PORT=4000