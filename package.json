{
  "name": "smarttest-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run api:dev\"",
    "dev:web": "vite",
    "api:dev": "npm --prefix backend run dev",
    "dev:tunnel": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run api:dev\"",
    "build:all": "npm run build && npm --prefix backend run build",
    "start": "npm --prefix backend run start"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^3.10.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "chart.js": "^4.4.6",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.11",
    "i18next": "^23.16.4",
    "lucide-react": "^0.563.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^15.1.3",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.4.15",
    "tailwind-merge": "^2.5.4",
    "typescript": "^5.6.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "vite": "^6.0.1",
    "vite-plugin-pwa": "^0.21.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "workbox-window": "^7.1.0"
  }
}
