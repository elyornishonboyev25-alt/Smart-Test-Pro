generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  OLYMPIAD
}

enum TestCategory {
  SCHOOL
  SAT
  IELTS
  OLYMPIAD
}

enum NotificationType {
  LEVEL_UP
  ACHIEVEMENT
  SYSTEM
}

enum LeaderboardPeriod {
  TODAY
  WEEK
  MONTH
  ALL_TIME
}

enum FocusTaskCategory {
  IELTS
  SAT
  ENGLISH_PRACTICE
}

enum FocusTaskKey {
  IELTS_READING
  IELTS_LISTENING
  IELTS_WRITING
  IELTS_SPEAKING
  SAT_MATH
  SAT_READING_WRITING
  SHADOWING
  ENGLISH_MOVIE
  VOCABULARY
}

enum FocusTaskStatus {
  LOCKED
  READY
  IN_PROGRESS
  COMPLETED
  SKIPPED
  MISSED
}

enum SpeakingQuestionSource {
  LICENSED
  USER_UPLOADED
  CURATED
}

enum SkillTrack {
  IELTS_LISTENING
  IELTS_READING
  IELTS_WRITING
  IELTS_SPEAKING
  SAT_MATH
  SAT_ENGLISH
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  passwordHash   String
  fullName       String
  nickname       String?            @unique
  role           Role               @default(USER)
  xp             Int                @default(0)
  level          Int                @default(1)
  currentStreak  Int                @default(0)
  longestStreak  Int                @default(0)
  lastActiveDate DateTime?
  avatarUrl      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  attempts       TestAttempt[]
  achievements   UserAchievement[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  dailyActivities DailyActivity[]
  leaderboardStates LeaderboardState[]
  tasks          UserTask[]
  focusPlans     FocusPlan[]
  focusDailyAnalytics FocusDailyAnalytics[]
  focusTaskLogs  FocusTaskLog[]
  aiPreference   UserAiPreference?
  aiMemories     AiMemory[]
  aiConversationThreads AiConversationThread[]
  vocabularyNotebooks VocabularyNotebook[]
  speakingEvaluations SpeakingEvaluation[]
  speakingSessions SpeakingSession[]
  shadowingVideos ShadowingVideo[]   @relation("ShadowingSubmitter")
  createdTests   Test[]             @relation("TestAuthor")
  profile        UserProfile?
  skillBadges    SkillBadge[]

  @@index([xp, level])
  @@index([createdAt])
}

// Extended, permanently-stored profile fields (identity, targets, privacy).
// One-to-one with User so the auth/core User row stays lean. Public-profile
// visibility is controlled per-section by the boolean flags below; email is
// never part of this model and is never exposed to other users.
model UserProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  phone                String?
  country              String?
  timezone             String?
  targetExam           String?  // 'IELTS' | 'SAT' | 'BOTH'
  targetScore          String?
  examDate             String?
  bio                  String?
  fieldOfStudy         String?
  gpa                  String?
  degreeLevel          String?  // 'bachelor' | 'master' | 'phd'
  budgetUsd            Int?
  targetUniversitySlug String?
  // Per-section public-profile visibility (profile itself is public by default).
  isPublic             Boolean  @default(true)
  showResults          Boolean  @default(true)
  showLeaderboard      Boolean  @default(true)
  showUniversity       Boolean  @default(true)
  showBadges           Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// One earned skill badge per (user, track, tier). Keeping tier in the unique key
// lets a learner hold several badges for the same track (e.g. Writing 6 AND 8) and
// pin whichever they want onto their public profile. `band` stores the best actual
// band that earned this tier (e.g. 8.5 for tier 8).
model SkillBadge {
  id         String     @id @default(cuid())
  userId     String
  track      SkillTrack
  tier       Int        // floor(band), clamped 6..9
  band       Float      // best actual band within this tier (e.g. 8.5)
  pinned     Boolean    @default(false)
  source     String?    // 'mock' | 'exam' | 'mock-arena'
  unlockedAt DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, track, tier])
  @@index([userId, pinned])
}

model SpeakingSession {
  id                String   @id @default(cuid())
  userId            String
  mode              String
  modeLabel         String
  overallBand       Float
  fluencyBand       Float
  lexicalBand       Float
  grammarBand       Float
  pronunciationBand Float
  durationSec       Int      @default(0)
  wordCount         Int      @default(0)
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserAiPreference {
  id                   String    @id @default(cuid())
  userId               String    @unique
  preferredLocale      String    @default("en")
  preferredName        String?
  toneStyle            String    @default("sweet")
  lastAssistantLanguage String   @default("en")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabNotebooks       VocabularyNotebook[]
  speakingEvaluations  SpeakingEvaluation[]

  @@index([preferredLocale])
}

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, updatedAt])
}

model VocabularyNotebook {
  id            String    @id @default(cuid())
  userId        String
  preferenceId  String?
  testKey       String
  title         String
  locale        String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference    UserAiPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  items         VocabularyNotebookItem[]

  @@unique([userId, testKey])
  @@index([userId, updatedAt])
}

model VocabularyNotebookItem {
  id          String   @id @default(cuid())
  notebookId  String
  term        String
  meaning     String
  notes       String?
  sourceLang  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  notebook    VocabularyNotebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)

  @@index([notebookId, createdAt])
}

model SpeakingEvaluation {
  id             String   @id @default(cuid())
  userId         String
  preferenceId   String?
  transcript     String
  overallBand    Float
  fluencyBand    Float
  grammarBand    Float
  pronunciationBand Float
  lexicalBand    Float
  feedback       Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference     UserAiPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model AiConversationThread {
  id         String                  @id @default(cuid())
  userId     String
  title      String
  locale     String                  @default("en")
  contextMode String                 @default("general")
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   AiConversationMessage[]

  @@index([userId, updatedAt])
}

model AiConversationMessage {
  id        String               @id @default(cuid())
  threadId  String
  role      String
  content   String
  locale    String               @default("en")
  createdAt DateTime             @default(now())
  thread    AiConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model SpeakingQuestionBank {
  id         String                @id @default(cuid())
  part       Int
  prompt     String
  followUps  Json?
  sourceType SpeakingQuestionSource @default(CURATED)
  sourceLabel String?
  isActive   Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([part, isActive])
  @@index([sourceType, isActive])
}

model UserTask {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  scheduledAt DateTime
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledAt])
  @@index([userId, completed, scheduledAt])
}

model FocusPlan {
  id                 String   @id @default(cuid())
  userId             String
  planDate           DateTime
  allowManualOverride Boolean @default(false)
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks              FocusTask[]
  dailyAnalytics     FocusDailyAnalytics?

  @@unique([userId, planDate])
  @@index([userId, planDate])
}

model FocusTask {
  id                String            @id @default(cuid())
  planId            String
  orderIndex        Int
  category          FocusTaskCategory
  moduleKey         FocusTaskKey
  title             String
  routePath         String
  estimatedMinutes  Int               @default(30)
  status            FocusTaskStatus   @default(LOCKED)
  completionPercent Float             @default(0)
  totalTimeSec      Int               @default(0)
  focusScore        Float             @default(0)
  startedAt         DateTime?
  unlockedAt        DateTime?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  plan              FocusPlan         @relation(fields: [planId], references: [id], onDelete: Cascade)
  logs              FocusTaskLog[]

  @@unique([planId, orderIndex])
  @@index([planId, status, orderIndex])
  @@index([moduleKey])
}

model FocusTaskLog {
  id           String   @id @default(cuid())
  taskId        String
  userId        String
  tabSessionId  String?
  startedAt     DateTime
  endedAt       DateTime?
  durationSec   Int      @default(0)
  activeSec     Int      @default(0)
  idleSec       Int      @default(0)
  focusScore    Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  task          FocusTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId, endedAt])
  @@index([userId, endedAt])
}

model FocusDailyAnalytics {
  id                String   @id @default(cuid())
  userId            String
  planId            String   @unique
  activityDate      DateTime
  totalPlannedTasks Int      @default(0)
  completedTasks    Int      @default(0)
  completionRate    Float    @default(0)
  totalStudyTimeSec Int      @default(0)
  averageSessionSec Float    @default(0)
  focusConsistency  Float    @default(0)
  averageFocusScore Float    @default(0)
  studyStreak       Int      @default(0)
  categoryBreakdown Json
  timeline          Json
  generatedAt       DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              FocusPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Test {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String
  category    TestCategory
  difficulty  Difficulty
  durationSec Int
  premium     Boolean       @default(false)
  xpReward    Int?
  subjects    String[]
  published   Boolean       @default(true)
  createdById String?
  createdBy   User?         @relation("TestAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  questions   TestQuestion[]
  attempts    TestAttempt[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category, difficulty, published])
  @@index([premium, published])
  @@index([createdAt])
}

model TestQuestion {
  id            String          @id @default(cuid())
  testId        String
  text          String
  explanation   String?
  order         Int
  weight        Float           @default(1)
  test          Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  options       TestOption[]
  attemptAnswers AttemptAnswer[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([testId, order])
  @@index([testId])
}

model TestOption {
  id         String          @id @default(cuid())
  questionId String
  text       String
  order      Int
  isCorrect  Boolean         @default(false)
  question   TestQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedIn AttemptAnswer[] @relation("SelectedOption")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([questionId, order])
  @@index([questionId])
  @@index([questionId, isCorrect])
}

model TestAttempt {
  id                 String         @id @default(cuid())
  userId             String
  testId             String
  startedAt          DateTime       @default(now())
  completedAt        DateTime       @default(now())
  timeSpentSec       Int
  totalQuestions     Int
  correctAnswers     Int
  rawScore           Float
  weightedScore      Float
  percentage         Float
  timeBonus          Float
  finalScore         Float
  accuracy           Float
  xpEarned           Int
  levelBefore        Int
  levelAfter         Int
  streakAtCompletion Int
  answers            AttemptAnswer[]
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  test               Test           @relation(fields: [testId], references: [id], onDelete: Cascade)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([userId, completedAt])
  @@index([testId, completedAt])
  @@index([finalScore, percentage])
}

model AttemptAnswer {
  id               String       @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String?
  isCorrect        Boolean
  weight           Float
  attempt          TestAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         TestQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOption   TestOption?  @relation("SelectedOption", fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model DailyActivity {
  id              String   @id @default(cuid())
  userId          String
  activityDate    DateTime
  testsCompleted  Int      @default(0)
  questionsAnswered Int    @default(0)
  xpEarned        Int      @default(0)
  averageScore    Float    @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([activityDate])
}

model Achievement {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  description    String
  icon           String
  xpReward       Int               @default(0)
  criteria       Json
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model LeaderboardState {
  id          String            @id @default(cuid())
  userId      String
  period      LeaderboardPeriod
  categoryKey String            @default("ALL")
  rank        Int
  previousRank Int?
  score       Float
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, categoryKey])
  @@index([period, categoryKey, rank])
}

// A shadowing-practice video added by any user from a YouTube link. Once a video
// is accepted (English captions + appropriate) it is saved here ONCE and becomes
// part of the shared library every user sees. `youtubeId` is unique so the same
// clip can never be added twice — the second submitter just reuses the saved copy.
model ShadowingVideo {
  id            String             @id @default(cuid())
  youtubeId     String             @unique
  title         String
  author        String?
  thumbnailUrl  String?
  durationSec   Int                @default(0)
  level         String             @default("Intermediate") // Beginner | Intermediate | Advanced (speech-rate heuristic)
  accent        String?
  topic         String?
  captionKind   String             @default("auto")          // manual | auto
  language      String             @default("en")
  segmentCount  Int                @default(0)
  wordCount     Int                @default(0)
  playCount     Int                @default(0)
  submittedById String?
  submittedBy   User?              @relation("ShadowingSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  segments      ShadowingSegment[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([createdAt])
  @@index([level])
}

// One shadowing chunk: a sentence-sized line with the exact start/end timestamps
// in the source video, so the player can loop just that line for repetition.
model ShadowingSegment {
  id         String         @id @default(cuid())
  videoId    String
  orderIndex Int
  startSec   Float
  endSec     Float
  text       String
  video      ShadowingVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, orderIndex])
  @@index([videoId, orderIndex])
}
