NODE_ENV=development
PORT=5001
CORS_ORIGIN=http://localhost:5173
# Local rivojlanish uchun: localhost Postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_test_pro
#
# PRODUCTION (Render) uchun: DOIMIY database ishlating — Render bepul PostgreSQL
# ~30 kunda o'chiriladi va barcha XP/test natijalari yo'qoladi. Neon (bepul, doimiy)
# tavsiya etiladi. Connection string oxiriga ?sslmode=require qo'shing:
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/smart_test_pro?sslmode=require
ACCESS_TOKEN_SECRET=smart_test_pro_access_secret_2026_local_12345
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=smart_test_pro_refresh_secret_2026_local_12345
REFRESH_TOKEN_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
HF_ACCESS_TOKEN=
HF_API_BASE=https://router.huggingface.co/v1
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_TIMEOUT_MS=20000
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
